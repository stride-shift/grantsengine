# ───────────────────────────────────────────────────────────
# d-lab Grant Engine — environment variables
# Copy to .env and fill in. Every var below is actually read by the code.
# ───────────────────────────────────────────────────────────

# ── AI: OpenAI (required for all AI features) ──
OPENAI_API_KEY=sk-proj-your-openai-key-here
# Optional overrides:
# OPENAI_MODEL=gpt-4o-mini          # default chat model
# OPENAI_SEARCH_MODEL=gpt-4o        # model used for web-search (Responses API) calls

# ── AI: Anthropic / Claude (used by the grant scraper; falls back to OpenAI if unset) ──
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5

# ── Server ──
PORT=3001
NODE_ENV=development
# Allowed browser origin(s) for CORS (comma-separated). Dev server runs on :3000.
CORS_ORIGIN=http://localhost:3000

# ── Database: Supabase Postgres ──
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Optional: enable strict TLS certificate verification by supplying Supabase's CA.
# Provide either an inline PEM or a path; if neither is set the connection is
# encrypted but the certificate is NOT verified.
# SUPABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# PGSSLROOTCERT=/path/to/prod-ca.crt

# ── Email (password-reset links) — Resend ──
RESEND_API_KEY=re_your-resend-key-here
EMAIL_FROM=Grants Engine <no-reply@your-domain.org>
# Base URL used to build reset links in emails
APP_URL=http://localhost:3000

# ── Google Calendar sync (OAuth) ──
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ── Admin / ops ──
# Master key required to create or delete organisations (keep long & random)
SUPER_ADMIN_KEY=change-me-to-a-long-random-string
# Shared secret that Vercel Cron must present to /api/cron/* endpoints
CRON_SECRET=change-me-to-a-long-random-string

# ── Playwright autofill/scraper service (separate process — see playwright-service/) ──
PLAYWRIGHT_SERVICE_URL=http://localhost:8080
PLAYWRIGHT_SECRET=dev-secret

# ── Optional scraper source: IATI Datastore (free key from developer.iatistandard.org) ──
# Without it the IATI source is skipped automatically; all other sources still run.
# IATI_API_KEY=your-free-iati-subscription-key

# ── Supabase MCP (local dev tooling only; consumed by mcp.json, not the app) ──
# SUPABASE_ACCESS_TOKEN=sbp_your-personal-access-token
# SUPABASE_PROJECT_REF=your-project-ref
