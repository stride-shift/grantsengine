                  style="width: 100%; height: 100%; border-radius: 3px; background: rgb(55, 65, 81); transition: width 0.5s ease;"
                />
              </div>
              <div
                style="width: 36px; font-size: 11px; font-weight: 700; color: rgb(28, 28, 28); font-family: "JetBrains Mono", "SF Mono", "Fira Code", monospace; text-align: right;"
              >
                1
              </div>
            </div>
          </div>
          <div
            style="padding: 14px 16px; background: rgb(255, 255, 255); border-radius: 10px; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04); border: 1px solid rgb(226, 230, 226); flex: 1 1 0%; min-width: 240px;"
          >
            <div
              style="font-size: 11px; font-weight: 700; color: rgb(17, 17, 17); margin-bottom: 4px;"
            >
              Deadline Pressure
            </div>
            <div
              style="font-size: 10px; color: rgb(107, 114, 128); margin-bottom: 10px;"
            >
              Submissions by month
            </div>
            <div
              style="display: flex; align-items: flex-end; gap: 6px; height: 80px;"
            >
              <div
                style="flex: 1 1 0%; display: flex; flex-direction: column; align-items: center; gap: 3px;"
              >
                <div
                  style="font-size: 10px; font-weight: 700; font-family: "JetBrains Mono", "SF Mono", "Fira Code", monospace; color: rgb(28, 28, 28);"
                >
                  1
                </div>
                <div
                  style="width: 100%; max-width: 32px; border-radius: 4px 4px 0 0; height: 50px; background: rgb(74, 124, 89); opacity: 1;"
                />
